# testora's own database + dev server
DATABASE_URL=postgres://e2e_testora:e2e_testora@localhost:55434/e2e-testing-db
BASE_URL=http://localhost:3000

# Optional: AI-drafted issue content for the Results "Generate issue" flow.
# Without a key, issues fall back to a deterministic template. Server-only.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Secret used to sign the "unlock" cookie for private apps (server-side only).
# Set a long random value in any shared/production deployment — otherwise the
# unlock cookie falls back to a known dev secret and could be forged.
# TESTORA_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# App under test (the "target") — testora is generic, so nothing about the
# specific app is hard-coded. Set these to whatever web app you point it at.
# ─────────────────────────────────────────────────────────────────────────────

# Credentials of the test account the suites log in with (must be admin /
# superadmin for the admin suites). Temp accounts are plus-addressed off this
# email so they land in an inbox you control.
WEBAPP_ADMIN_EMAIL=
WEBAPP_ADMIN_PASSWORD=

# Default local target (used by the seed data's FR baseUrl and the scripts'
# t.request calls when no run-time override is chosen).
WEBAPP_BASE_URL=http://localhost:3233
WEBAPP_API_URL=http://localhost:3234/api/v1

# Optional remote/staging target, surfaced as the "Remote" preset on the Run
# page's environment selector. Leave blank to hide it.
# NEXT_PUBLIC_* values are needed because the Run page reads them in the browser.
NEXT_PUBLIC_WEBAPP_BASE_URL=http://localhost:3233
NEXT_PUBLIC_WEBAPP_API_URL=http://localhost:3234/api/v1
NEXT_PUBLIC_WEBAPP_REMOTE_BASE_URL=
NEXT_PUBLIC_WEBAPP_REMOTE_API_URL=

# Optional overrides for the Immo Local app. Defaults to the same local dev
# target as ImmoStory above.
# NEXT_PUBLIC_IMMO_LOCAL_NAME=Immo Local
# NEXT_PUBLIC_IMMO_LOCAL_BASE_URL=http://localhost:3233
# NEXT_PUBLIC_IMMO_LOCAL_API_URL=http://localhost:3234/api/v1
