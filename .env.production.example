# ─────────────────────────────────────────────────────────────────────────────
# Production env for testora.asafarim.com  →  copy to ".env" on the VPS.
# Read by both the systemd service (runtime) and pnpm db:migrate / db:seed.
# systemd EnvironmentFile reads values verbatim: NO surrounding quotes.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Local Postgres docker container (deploy/docker-compose.prod.yml),
# published on 127.0.0.1:55434 only.
DATABASE_URL=postgres://e2e_testora:e2e_testora@127.0.0.1:55434/e2e-testing-db

# REQUIRED in production: signs the private-app unlock cookie. Generate once,
# e.g. `openssl rand -hex 32`, and keep it stable (changing it logs everyone out
# of unlocked private apps). Without it, unlock cookies could be forged.
TESTORA_SECRET=

# The app's own public URL. PORT/HOSTNAME are passed on the systemd ExecStart
# line; BASE_URL is what the UI advertises.
BASE_URL=https://testora.asafarim.com

# Browser TestCafe drives for runs. Host has google-chrome; hardened headless
# flags avoid sandbox/shm failures when launched from the service process.
E2E_BROWSER=chrome:headless --no-sandbox --disable-gpu --disable-dev-shm-usage
CHROME_BIN=/usr/bin/google-chrome
CHROME_PATH=/usr/bin/google-chrome

# Optional: AI-drafted issue content on the Results "Generate issue" flow. With
# no key set, issues fall back to a deterministic template. Server-only.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ─── App under test (the "target") ──────────────────────────────────────────
# Admin/superadmin account the suites log in with. FILL THESE IN.
WEBAPP_ADMIN_EMAIL=
WEBAPP_ADMIN_PASSWORD=
WEBAPP_ROLE=superadmin

# Default target the seed FRs / scripts point at.
WEBAPP_BASE_URL=https://immostory.ai
WEBAPP_API_URL=https://api.immostory.ai/api/v1

# Surfaced in the browser on the Run page (must be NEXT_PUBLIC_*).
NEXT_PUBLIC_WEBAPP_BASE_URL=https://immostory.ai
NEXT_PUBLIC_WEBAPP_API_URL=https://api.immostory.ai/api/v1
NEXT_PUBLIC_WEBAPP_REMOTE_BASE_URL=
NEXT_PUBLIC_WEBAPP_REMOTE_API_URL=

# Optional overrides for the Immo Local app. Defaults to the same local dev
# target as ImmoStory above.
# NEXT_PUBLIC_IMMO_LOCAL_NAME=Immo Local
# NEXT_PUBLIC_IMMO_LOCAL_BASE_URL=http://localhost:3233
# NEXT_PUBLIC_IMMO_LOCAL_API_URL=http://localhost:3234/api/v1
